  -- =========================================================
-- AJUSTES OPCIONALES PARA TU TABLA matches
-- =========================================================

alter table matches
add column if not exists external_id text;

alter table matches
add column if not exists tournament text default 'Mundial 2026';

alter table matches
add column if not exists stage text default 'Fase de grupos';

alter table matches
add column if not exists group_name text;

create unique index if not exists matches_external_id_idx
on matches (external_id);


